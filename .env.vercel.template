# ============================================
# 🔐 VERCEL ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copia estas variables a Vercel Dashboard
# Settings → Environment Variables → Add New
# Aplica a: Production, Preview, Development
# ============================================

# ===================================
# 🎯 OBLIGATORIAS — sin estas el app no arranca
# ===================================

# Database - Supabase PostgreSQL (pooler mode)
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Redis Cache - Upstash (FREE: 10K cmd/day — https://upstash.com)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxx...

# NextAuth / Auth.js
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://tu-proyecto.vercel.app
AUTH_URL=https://tu-proyecto.vercel.app

# Google OAuth (https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs)
# URI de redirección autorizado: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ===================================
# 🔒 SEGURIDAD — STRY-021 (requeridas en producción)
# ===================================

# Cola de notificaciones (WhatsApp vía n8n)
# Generar: openssl rand -hex 32
SCHEDULED_NOTIFICATIONS_API_KEY=generate-with-openssl-rand-hex-32

# Cifrado AES-256 de tokens OAuth (Instagram, Facebook, WhatsApp)
# CRITICO: sin esto los tokens se guardan en texto plano
# Generar: openssl rand -hex 32
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# WhatsApp Cloud API (Meta Developer Dashboard → WhatsApp Business → API Setup)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=generate-a-random-string
# App Secret para verificación HMAC-SHA256 del webhook
# Meta Developer Dashboard → App → Settings → Basic → App Secret
WHATSAPP_APP_SECRET=your-app-secret

# Endpoints de diagnóstico — proteger en staging
# Generar: openssl rand -hex 32
DIAGNOSE_SECRET_TOKEN=generate-with-openssl-rand-hex-32
REQUIRE_DIAGNOSE_AUTH=true

# ===================================
# 🔌 RECOMENDADAS
# ===================================

# Google Sign-In ya configurado arriba
# API URL (mismo dominio que NEXTAUTH_URL)
NEXT_PUBLIC_API_URL=https://tu-proyecto.vercel.app

# MercadoPago — Pagos México MXN
# https://www.mercadopago.com.mx/developers → Credenciales
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-...
MP_WEBHOOK_SECRET=generate-a-random-string
MP_SANDBOX=false
MP_CURRENCY=MXN
MP_COUNTRY=MX

# Email — Resend (FREE: 3,000 emails/mes — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=notificaciones@tu-dominio.com

# Cloudinary — imágenes (FREE: 25GB — https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Domain Configuration (si usas dominio custom)
NEXT_PUBLIC_DOMAIN=tuapp.com
NEXT_PUBLIC_TENANT_DOMAIN_PATTERN=*.tuapp.com

# ===================================
# ⚠️  E2E / Staging — NO usar en producción
# ===================================
# E2E_TEST_USER_EMAIL=e2e-admin@test.internal
# E2E_TEST_USER_PASSWORD=change-me-in-env-local
# E2E_SEED_SECRET=generate-with-openssl-rand-hex-32

# ===================================
# 📝 NOTAS IMPORTANTES
# ===================================
#
# 1. NO commitees este archivo con valores reales
# 2. Configura las variables en Vercel Dashboard, no en archivos .env
# 3. NEXTAUTH_URL y AUTH_URL deben ser la URL exacta de producción (con https://)
# 4. DATABASE_URL: usa el pooler de Supabase (puerto 6543) para Vercel serverless
# 5. Después del primer deploy, actualiza NEXTAUTH_URL con tu URL definitiva
# 6. ENCRYPTION_KEY es irreversible: si cambia, los tokens OAuth guardados se invalidan
#
# Generar secretos seguros:
#   openssl rand -base64 32   → para NEXTAUTH_SECRET / AUTH_SECRET
#   openssl rand -hex 32      → para ENCRYPTION_KEY, SCHEDULED_NOTIFICATIONS_API_KEY, DIAGNOSE_SECRET_TOKEN
# ===================================
