# WA Platform — Variables de entorno requeridas
# Copiar a .env.local y completar los valores

# n8n
N8N_BASE_URL=http://127.0.0.1:5678
N8N_WEBHOOK_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=cambiar-por-secret-seguro

# Redis (Upstash en producción, local en dev)
UPSTASH_REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_TOKEN=

# Meta / WhatsApp
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Claude AI (para hybrid response layer)
ANTHROPIC_API_KEY=
