# ===================================
# 🎯 REQUERIDAS PARA FUNCIONAMIENTO
# ===================================

# Database - Neon PostgreSQL (FREE: 3GB storage, 192 compute hours/month)
# Crear cuenta gratis en: https://neon.tech
DATABASE_URL="postgresql://username:password@ep-xxx-xxx.us-east-1.aws.neon.tech/sass_store?sslmode=require"

# Redis Cache - Upstash (FREE: 10K commands/day, 256MB)
# Crear cuenta gratis en: https://upstash.com
UPSTASH_REDIS_REST_URL="https://your-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxxx..."

# NextAuth / Auth.js (@sass-store/web usa `next dev -p 3001`)
# Generar secret con: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3001"
AUTH_URL="http://localhost:3001"

# Google Sign-In (mismo Client ID que en Google Cloud → OAuth 2.0 Client IDs)
# URI de redirección autorizado: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-..."

# ===================================
# REQUERIDAS EN PRODUCCION
# ===================================
# Sin estas variables el sistema falla silenciosamente en produccion.
# Generarlas ANTES de hacer deploy.

# Cola de notificaciones - Bearer token para n8n/worker
# REQUERIDO si usas el modulo de notificaciones (WhatsApp reschedule, etc.)
# Generar: openssl rand -hex 32
SCHEDULED_NOTIFICATIONS_API_KEY="generate-with-openssl-rand-hex-32"

# Cifrado de tokens de redes sociales (Instagram, Facebook, WhatsApp Business)
# REQUERIDO: sin esto los tokens se guardan en texto plano
# Generar: openssl rand -hex 32
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# WhatsApp Cloud API - REQUERIDO para envio de mensajes via n8n
# Obtener en: https://developers.facebook.com > WhatsApp Business > API Setup
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-permanent-access-token"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="generate-a-random-string"

# ===================================
# OPCIONALES (pueden omitirse)
# ===================================

# Stripe Configuration (solo si usas pagos con Stripe — el proyecto usa MercadoPago por defecto)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:4000"

# File Storage (Cloudflare R2)
CLOUDFLARE_R2_ACCESS_KEY_ID="..."
CLOUDFLARE_R2_SECRET_ACCESS_KEY="..."
CLOUDFLARE_R2_BUCKET_NAME="sass-store-media"
CLOUDFLARE_R2_ENDPOINT="https://..."

# Email Service (Optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Domain Configuration
NEXT_PUBLIC_DOMAIN="localhost:3001"
NEXT_PUBLIC_TENANT_DOMAIN_PATTERN="*.localhost:3001"

# Analytics (Optional)
GOOGLE_ANALYTICS_ID="GA-..."
FACEBOOK_PIXEL_ID="..."

# Google Calendar Integration (Optional)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CALENDAR_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CALENDAR_CLIENT_SECRET="GOCSPX-your-client-secret"
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Development/Production Flag
NODE_ENV="development"