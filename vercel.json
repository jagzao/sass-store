{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "cd apps/web && npm run build",
  "outputDirectory": "apps/web/.next",
  "devCommand": "npm run dev",
  "framework": "nextjs",
  "functions": {
    "app/api/health/**": { "maxDuration": 5 },
    "app/api/v1/social/media/**": { "maxDuration": 60 },
    "app/**/*": { "maxDuration": 30 }
  }
}
