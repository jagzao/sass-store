{
  "rootDirectory": "apps/web",
  "installCommand": "cd ../.. && npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "devCommand": "cd ../.. && npm run dev",
  "framework": "nextjs",
  "functions": {
    "app/api/health/**": { "maxDuration": 5 },
    "app/api/v1/social/media/**": { "maxDuration": 60 },
    "app/**/*": { "maxDuration": 30 }
  }
}
